{
  "AQML Strategy Skeleton": {
    "prefix": "aqml",
    "description": "Complete AQML v2 strategy scaffold",
    "body": [
      "version: \"2.0\"",
      "",
      "name: ${1:Strategy Name}",
      "description: \"${2:Brief description}\"",
      "signal_type: ${3|buy,sell|}",
      "",
      "filters:",
      "  exclude_st: true",
      "  exclude_kcb: true",
      "  exclude_bj: true",
      "",
      "rules:",
      "  - type: compare",
      "    left: ${4:close}",
      "    operator: \"${5|>,>=,<,<=,==,!=|}\"",
      "    right: ${6:ma20}",
      "    comment: \"${7:Close above MA20}\"",
      "",
      "scoring:",
      "  max_score: ${8:100}",
      "  min_score: ${9:60}",
      "  rule_points:",
      "    - points: ${10:100}",
      "",
      "exit_rules:",
      "  stop_loss_pct: ${11:5.0}",
      "  take_profit_pct: ${12:15.0}",
      "  max_holding_days: ${13:20}",
      "",
      "portfolio:",
      "  method: ${14|equal_weight,score_weighted|}",
      "  max_positions: ${15:10}",
      "  initial_capital: ${16:1000000}",
      "$0"
    ]
  },
  "Compare Rule": {
    "prefix": "rule-compare",
    "description": "AQML compare rule",
    "body": [
      "- type: compare",
      "  left: ${1:close}",
      "  operator: \"${2|>,>=,<,<=,==,!=|}\"",
      "  right: ${3:ma20}",
      "  comment: \"${4:Close above MA20}\""
    ]
  },
  "Compare All Rule": {
    "prefix": "rule-compare-all",
    "description": "AQML compare_all rule",
    "body": [
      "- type: compare_all",
      "  price: ${1:close}",
      "  indicators: [${2:ma60}, ${3:ma90}, ${4:ma125}, ${5:ma250}]",
      "  operator: \"${6|>,>=,<,<=|}\"",
      "  min_above_pct: ${7:1.0}",
      "  max_above_pct: ${8:5.0}",
      "  comment: \"${9:Above all long moving averages}\""
    ]
  },
  "Range Rule": {
    "prefix": "rule-range",
    "description": "AQML range rule",
    "body": [
      "- type: range",
      "  indicator: ${1:rsi14}",
      "  min: ${2:0}",
      "  max: ${3:30}",
      "  comment: \"${4:RSI oversold}\""
    ]
  },
  "Signal Rule": {
    "prefix": "rule-signal",
    "description": "AQML signal detection rule",
    "body": [
      "- type: signal",
      "  indicator: ${1|macd,kdj,ma|}",
      "  signal: ${2|golden_cross,death_cross|}",
      "  offset: ${3:0}",
      "  comment: \"${4:Signal detected}\""
    ]
  },
  "Pattern Rule": {
    "prefix": "rule-pattern",
    "description": "AQML candlestick pattern rule",
    "body": [
      "- type: pattern",
      "  pattern: ${1|hammer,engulfing_bull,engulfing_bear,doji,morning_star,evening_star|}",
      "  offset: ${2:0}",
      "  comment: \"${3:Pattern matched}\""
    ]
  },
  "Breakout Rule": {
    "prefix": "rule-breakout",
    "description": "AQML breakout detection rule",
    "body": [
      "- type: breakout",
      "  price: ${1:close}",
      "  level: ${2:boll_upper}",
      "  direction: ${3|up,down|}",
      "  offset: ${4:0}",
      "  comment: \"${5:Breakout detected}\""
    ]
  },
  "OR Logic Group": {
    "prefix": "rule-or",
    "description": "AQML OR logic group",
    "body": [
      "- logic: or",
      "  comment: \"${1:Any condition passes}\"",
      "  conditions:",
      "    - type: signal",
      "      indicator: ${2|macd,kdj,ma|}",
      "      signal: ${3|golden_cross,death_cross|}",
      "      offset: 0",
      "      comment: \"${4:Primary signal}\"",
      "    - type: signal",
      "      indicator: ${5|macd,kdj,ma|}",
      "      signal: ${6|golden_cross,death_cross|}",
      "      offset: -1",
      "      comment: \"${7:Secondary signal}\""
    ]
  },
  "Filters Block": {
    "prefix": "filters",
    "description": "AQML filters configuration",
    "body": [
      "filters:",
      "  exclude_st: true",
      "  exclude_kcb: true",
      "  exclude_bj: true",
      "  min_market_cap: ${1:30}",
      "  min_amount: ${2:5000}"
    ]
  },
  "Scoring Block": {
    "prefix": "scoring",
    "description": "AQML scoring configuration",
    "body": [
      "scoring:",
      "  max_score: ${1:100}",
      "  min_score: ${2:60}",
      "  rule_points:",
      "    - points: ${3:50}",
      "    - points: ${4:50}"
    ]
  },
  "Tiered Rule Points": {
    "prefix": "scoring-tier",
    "description": "AQML tiered scoring entry",
    "body": [
      "- points: ${1:40}",
      "  tiers:",
      "    - condition: {indicator: ${2:rsi14}, min: ${3:30}, max: ${4:40}}",
      "      points: ${5:20}"
    ]
  },
  "Exit Rules Block": {
    "prefix": "exit",
    "description": "AQML exit rules",
    "body": [
      "exit_rules:",
      "  stop_loss_pct: ${1:5.0}",
      "  take_profit_pct: ${2:15.0}",
      "  trailing_stop_pct: ${3:8.0}",
      "  max_holding_days: ${4:20}"
    ]
  },
  "Portfolio Block": {
    "prefix": "portfolio",
    "description": "AQML portfolio configuration",
    "body": [
      "portfolio:",
      "  method: ${1|equal_weight,score_weighted|}",
      "  max_positions: ${2:10}",
      "  initial_capital: ${3:1000000}"
    ]
  },
  "Risk Block": {
    "prefix": "risk",
    "description": "AQML risk management parameters",
    "body": [
      "risk:",
      "  max_drawdown: ${1:15.0}",
      "  max_single_position: ${2:10.0}"
    ]
  }
}

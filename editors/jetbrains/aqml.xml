<?xml version="1.0" encoding="UTF-8"?>
<!--
  AQML File Type Definition for JetBrains IDEs
  (IntelliJ IDEA, PyCharm, WebStorm, GoLand, etc.)

  Installation:
    Settings → Editor → File Types → + (Add)
    Or copy to: ~/.config/JetBrains/<IDE>/filetypes/aqml.xml
-->
<filetype binary="false" default_extension="aqml" description="AQML Strategy File" name="AQML">
  <highlighting>
    <options>
      <option name="LINE_COMMENT" value="#" />
      <option name="COMMENT_START" value="" />
      <option name="COMMENT_END" value="" />
      <option name="HEX_PREFIX" value="0x" />
      <option name="NUM_POSTFIXES" value="" />
      <option name="HAS_BRACES" value="false" />
      <option name="HAS_BRACKETS" value="true" />
      <option name="HAS_PARENS" value="false" />
      <option name="HAS_STRING_ESCAPES" value="true" />
    </options>
    <keywords keywords="aqml;name;description;version;metadata;universe;rules;scoring;exit_rules;portfolio;risk" ignore_case="false" />
    <keywords2 keywords="type;field;operator;value;reference;multiplier;min;max;inclusive;indicator;signal;pattern;direction;lookback;confirmation_bars;weight;enabled;mode;min_score;method;max_positions;max_sector_pct;rebalance;stop_loss;take_profit;trailing_stop;max_holding_days;max_drawdown;max_single_position;max_sector_concentration;var_limit;correlation_threshold;market;exclude;filters;author;created_at;tags;category;source" ignore_case="false" />
    <keywords3 keywords="compare;range;signal;pattern;breakout;golden_cross;death_cross;zero_cross_up;zero_cross_down;overbought;oversold;long_arrangement;short_arrangement;squeeze;expansion;upper_touch;lower_touch;hammer;engulfing_bull;engulfing_bear;doji;morning_star;evening_star;three_white_soldiers;three_black_crows" ignore_case="false" />
    <keywords4 keywords="weighted;equal;threshold;equal_weight;score_weighted;market_cap_weighted;kelly;risk_parity;daily;weekly;biweekly;monthly;A-shares;A-shares-main;custom;ST;STAR;BSE;ChiNext;new_listing;above;below;true;false" ignore_case="false" />
  </highlighting>
  <extensionMap>
    <mapping ext="aqml" />
  </extensionMap>
</filetype>
